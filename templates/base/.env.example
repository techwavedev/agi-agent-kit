# AGI Agent Kit - Environment Configuration
# Copy this file to .env and fill in your values

# --- Core Settings ---
# Project environment (development/production)
ENVIRONMENT=development
# Debug mode for verbose logging
DEBUG=false

# --- AI Model Providers ---
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI (GPT-4)
OPENAI_API_KEY=sk-...
# Google (Gemini)
GOOGLE_API_KEY=AIza...

# --- Agent Memory (Qdrant + Ollama) ---
# Set during `init`. Change to true/false to toggle the local memory system.
# When true: the agent persists semantic memories in Qdrant and generates
# embeddings via Ollama (nomic-embed-text) — fully local & private.
# When false: memory is disabled; only cloud/API providers are used.
MEMORY_ENABLED=false

# Qdrant vector database URL (default: localhost:6333 for local Docker)
QDRANT_URL=http://localhost:6333
# Qdrant API Key (leave empty for local; required for Qdrant Cloud)
QDRANT_API_KEY=
# Name of the Qdrant collection used for agent memory
QDRANT_COLLECTION=agent_memory

# Ollama embedding settings (only used when MEMORY_ENABLED=true)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Semantic cache settings
# Cosine similarity threshold (0–1) above which a cached response is reused
CACHE_THRESHOLD=0.92
# How many days cached entries are kept before expiry
CACHE_TTL_DAYS=7

# --- Knowledge Skills ---

# Webcrawler
# User agent string for polite crawling
USER_AGENT=AGI-Agent-Bot/1.0
# Maximum depth for recursive crawling (safety limit)
MAX_CRAWL_DEPTH=5

# GitHub/GitLab (for DevOps skills)
GITHUB_TOKEN=ghp_...
GITLAB_TOKEN=glpat-...

# Cloud Providers (for Infrastructure skills)
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# Security Scanner
# OWASP ZAP API Key (optional)
ZAP_API_KEY=
# Snyk API Token (optional)
SNYK_TOKEN=

# Monitoring & Logging
# Sentry DSN
SENTRY_DSN=
# Datadog API Key
DD_API_KEY=

# --- Memory Mode (solo / team / pro) ---
# solo  = Ollama + Qdrant only (single developer, no identity tagging)
# team  = + Multi-tenancy (developer/agent identity, shared memory, isolation)
# pro   = + Blockchain auth (signed writes, hash anchoring, access control)
MEMORY_MODE=team

# Developer identity (optional — auto-detected from git config user.email)
# AGI_DEVELOPER_ID=your@email.com
# AGI_AGENT_ID=my-agent

# --- Hyperledger Aries — Blockchain Auth (pro mode only, optional add-on) ---
# Only needed if MEMORY_MODE=pro. Solo and team modes ignore these entirely.
# Start with: docker compose -f docker-compose.aries.yml up -d
ARIES_ADMIN_URL=http://localhost:8031
ARIES_ADMIN_KEY=changeme_use_a_strong_api_key
ARIES_WALLET_KEY=changeme_use_a_strong_wallet_key
ARIES_HTTP_PORT=8030
ARIES_ADMIN_PORT=8031
