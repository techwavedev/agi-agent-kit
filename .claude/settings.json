{
  "permissions": {
    "allow": [
      "Bash(git cherry-pick:*)",
      "Bash(git stash:*)"
    ],
    "additionalDirectories": [
      "/tmp/stash_other_work"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre_tool_enforce.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Grep|WebFetch|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_filter.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_reinject.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
