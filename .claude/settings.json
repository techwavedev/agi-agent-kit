{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_session_start.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre_tool_enforce.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/local_router_hook.py",
            "timeout": 35
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Grep|WebFetch|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_filter.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/context_reinject.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}