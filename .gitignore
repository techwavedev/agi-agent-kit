# (these are listed in .private so they never leak to the public release)
!.claude/hooks/
!.claude/hooks/*.py
.claude/hooks/__pycache__/
!.claude/settings.json
.gemini/
*.skill


# Agent worktrees (parallel isolation)
.worktrees/

