# Credentials (all directories, all variants)
.env
.env.*
!.env.example
credentials.json
token.json
*.pem
*.key

# Temp files
.tmp/
!.tmp/.gitkeep

# Airgap release clone (never commit into private repo)
public_release_repo/
public_release/
public/

# Python
__pycache__/
*.py[cod]
venv/
